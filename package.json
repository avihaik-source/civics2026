{
  "name": "civics2026",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run minify:dist",
    "minify:dist": "echo 'INFO: Minification temporarily disabled to preserve practiceQuestions data. Files kept at full size for debugging. Will re-enable after Terser config fix.'",
    "preview": "wrangler pages dev dist",
    "deploy": "npm run build && wrangler pages deploy dist --project-name civics2026",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "dev:d1": "wrangler pages dev dist --d1=civics2026-production --local --ip 0.0.0.0 --port 3000",
    "db:migrate:local": "wrangler d1 migrations apply civics2026-production --local",
    "db:migrate:prod": "wrangler d1 migrations apply civics2026-production",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && npm run db:migrate:local",
    "db:console:local": "wrangler d1 execute civics2026-production --local"
  },
  "dependencies": {
    "hono": "^4.12.9"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260301.1",
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.25.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "clean-css-cli": "^4.0.12",
    "terser": "^5.46.0",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
