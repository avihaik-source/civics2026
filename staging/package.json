{
  "name": "civics2026",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build --outDir dist/client",
    "build:server": "vite build --ssr src/main.tsx --outDir dist/server",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "hono": "^4.12.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260301.1",
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.25.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "clean-css-cli": "^4.0.12",
    "terser": "^5.46.0",
    "vite": "^8.0.3",
    "wrangler": "^4.78.0"
  }
}
