  "d1_databases": [{
    "binding": "DB",
    "database_name": "civics2026-production",
    "database_id": "93488a89-9448-4cb9-998b-e4fad7b045aa"
  }],
  "vars": { "TEACHER_PASSWORD": "0512" }
}