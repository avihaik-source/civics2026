{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "civics2026",
  "compatibility_date": "2026-03-01",
  "main": "index.tsx", 
  "assets": {
    "directory": "./dist"
  },
  "compatibility_flags": ["nodejs_compat"],
  "ai": { "binding": "AI" },
